sub:assertion {
  <https://doi.org/10.1126/science.aax8591> <http://purl.org/spar/cito/hasQuotedText>
      "Increasing frequency of hotter temperatures predicts species’ local extinction risk, chances of colonizing a new area, and changing species richness.";
    <http://www.w3.org/2000/01/rdf-schema#comment> "This sentence defines the mechanism our replication projects forward in time: temperatures exceeding species’ historical thermal tolerances drive local extinction, colonization, and richness change. The original study validated this retrospectively for 66 Bombus species in North America and Europe (~50 km, monthly). We test its transferability to the Iberian Peninsula under SSP3-7.0 using DestinE Climate DT output (~5 km, daily)." .
  
  <https://w3id.org/np/o/ntemplate/CREATOR> <http://purl.org/spar/cito/quotes> <https://doi.org/10.1126/science.aax8591> .
}

sub:provenance {
  sub:assertion prov:wasAttributedTo <https://orcid.org/0000-0002-1784-2920> .
}

